{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MBE Materialized Workload Record v1",
  "type": "object",
  "allOf": [{"$ref": "mbe_workload_record_v1.schema.json"}],
  "required": [
    "materialized_index",
    "logical_event_id",
    "occurrence_index",
    "schema_version",
    "dataset_id",
    "source_row_index",
    "source_event_id",
    "sender_id",
    "operation_type",
    "state_keys",
    "routing_source_key"
  ],
  "properties": {
    "materialized_index": {"type": "integer", "minimum": 0},
    "logical_event_id": {"type": "string", "minLength": 1},
    "occurrence_index": {"type": "integer", "minimum": 0}
  }
}
